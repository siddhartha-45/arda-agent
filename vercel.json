{
  "projectName": "arda-research-agent",
  "name": "arda-research-agent",
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "GROQ_API_KEY": "@groq_api_key",
    "PYTHON_VERSION": "3.11"
  }
}
